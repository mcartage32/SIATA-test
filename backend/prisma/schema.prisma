generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model app_user {
  id         Int       @id @default(autoincrement())
  mask_uuid  String    @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email      String    @unique @db.VarChar(150)
  password   String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  created_by String?   @db.VarChar(100)
  updated_by String?   @db.VarChar(100)
  updated_at DateTime? @db.Timestamptz(6)
}

model client {
  id         Int        @id @default(autoincrement())
  mask_uuid  String     @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String     @db.VarChar(100)
  email      String     @unique @db.VarChar(150)
  phone      String?    @db.VarChar(20)
  created_at DateTime?  @default(now()) @db.Timestamptz(6)
  created_by String?    @db.VarChar(100)
  updated_by String?    @db.VarChar(100)
  updated_at DateTime?  @db.Timestamptz(6)
  shipment   shipment[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model land_shipment {
  shipment_id   Int       @id
  mask_uuid     String    @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  warehouse_id  Int
  vehicle_plate String    @db.VarChar(6)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  created_by    String?   @db.VarChar(100)
  updated_by    String?   @db.VarChar(100)
  updated_at    DateTime? @db.Timestamptz(6)
  shipment      shipment  @relation(fields: [shipment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  warehouse     warehouse @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model port {
  id           Int            @id @default(autoincrement())
  mask_uuid    String         @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String         @db.VarChar(100)
  location     String?        @db.VarChar(150)
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  created_by   String?        @db.VarChar(100)
  updated_by   String?        @db.VarChar(100)
  updated_at   DateTime?      @db.Timestamptz(6)
  sea_shipment sea_shipment[]
}

model product {
  id            Int             @id @default(autoincrement())
  mask_uuid     String          @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String          @db.VarChar(100)
  description   String?
  price         Decimal         @db.Decimal(10, 2)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  created_by    String?         @db.VarChar(100)
  updated_by    String?         @db.VarChar(100)
  updated_at    DateTime?       @db.Timestamptz(6)
  shipment_item shipment_item[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sea_shipment {
  shipment_id  Int       @id
  mask_uuid    String    @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  port_id      Int
  fleet_number String    @db.VarChar(8)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  created_by   String?   @db.VarChar(100)
  updated_by   String?   @db.VarChar(100)
  updated_at   DateTime? @db.Timestamptz(6)
  port         port      @relation(fields: [port_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shipment     shipment  @relation(fields: [shipment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model shipment {
  id                Int             @id @default(autoincrement())
  mask_uuid         String          @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type              String          @db.VarChar(20)
  client_id         Int
  registration_date DateTime?       @default(now()) @db.Timestamptz(6)
  delivery_date     DateTime        @db.Date
  base_price        Decimal         @db.Decimal(10, 2)
  discount_percent  Decimal?        @default(0) @db.Decimal(5, 2)
  discount_amount   Decimal?        @default(0) @db.Decimal(10, 2)
  total_price       Decimal         @db.Decimal(10, 2)
  guide_number      String          @unique @db.VarChar(10)
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  created_by        String?         @db.VarChar(100)
  updated_by        String?         @db.VarChar(100)
  updated_at        DateTime?       @db.Timestamptz(6)
  land_shipment     land_shipment?
  sea_shipment      sea_shipment?
  client            client          @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shipment_item     shipment_item[]

  @@index([client_id], map: "idx_shipment_client")
  @@index([registration_date], map: "idx_shipment_registration_date")
  @@index([type], map: "idx_shipment_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model shipment_item {
  id          Int       @id @default(autoincrement())
  mask_uuid   String    @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  shipment_id Int
  product_id  Int
  quantity    Int
  unit_price  Decimal   @db.Decimal(10, 2)
  total_price Decimal   @db.Decimal(10, 2)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  created_by  String?   @db.VarChar(100)
  updated_by  String?   @db.VarChar(100)
  updated_at  DateTime? @db.Timestamptz(6)
  product     product   @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shipment    shipment  @relation(fields: [shipment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_shipment_item_product")
  @@index([shipment_id], map: "idx_shipment_item_shipment")
}

model warehouse {
  id            Int             @id @default(autoincrement())
  mask_uuid     String          @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String          @db.VarChar(100)
  location      String?         @db.VarChar(150)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  created_by    String?         @db.VarChar(100)
  updated_by    String?         @db.VarChar(100)
  updated_at    DateTime?       @db.Timestamptz(6)
  land_shipment land_shipment[]
}
